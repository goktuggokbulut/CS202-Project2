<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.RestaurantSettingsController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <Label text="My Restaurant" style="-fx-font-size: 28px; -fx-font-weight: bold;" />
        <Region HBox.hgrow="ALWAYS" />
        <!-- Shown only when manager has multiple restaurants -->
        <ComboBox fx:id="restaurantSelector" prefWidth="240" promptText="Select restaurant"
                  visible="false" managed="false" />
    </HBox>

    <Separator />

    <!-- Status / hint message -->
    <Label fx:id="statusLabel" text="" wrapText="true" visible="false"
           style="-fx-font-size: 13px;" />

    <!-- Form card -->
    <VBox fx:id="formBox" spacing="15.0"
          style="-fx-background-color: white; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 25;">

        <Label fx:id="formTitleLabel" text="Restaurant Details"
               style="-fx-font-size: 18px; -fx-font-weight: bold;" />

        <GridPane hgap="15.0" vgap="12.0">
            <columnConstraints>
                <ColumnConstraints prefWidth="140" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <Label text="Restaurant Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                   style="-fx-font-weight: bold;" />
            <TextField fx:id="nameField" promptText="e.g. Bosphorus Grill"
                       GridPane.rowIndex="0" GridPane.columnIndex="1" />

            <Label text="Cuisine Type:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                   style="-fx-font-weight: bold;" />
            <TextField fx:id="cuisineField" promptText="e.g. Turkish, Italian, Japanese"
                       GridPane.rowIndex="1" GridPane.columnIndex="1" />

            <Label text="Address:" GridPane.rowIndex="2" GridPane.columnIndex="0"
                   style="-fx-font-weight: bold;" />
            <TextField fx:id="addressField" promptText="Full street address"
                       GridPane.rowIndex="2" GridPane.columnIndex="1" />

            <Label text="City:" GridPane.rowIndex="3" GridPane.columnIndex="0"
                   style="-fx-font-weight: bold;" />
            <TextField fx:id="cityField" promptText="e.g. Istanbul"
                       GridPane.rowIndex="3" GridPane.columnIndex="1" />

            <Label text="Keywords:" GridPane.rowIndex="4" GridPane.columnIndex="0"
                   style="-fx-font-weight: bold;" />
            <TextField fx:id="keywordsField" promptText="Comma-separated, e.g. grill, kebap, meze"
                       GridPane.rowIndex="4" GridPane.columnIndex="1" />

        </GridPane>

        <Label text="Keywords are used by customers to search and discover your restaurant."
               style="-fx-text-fill: #57606a; -fx-font-size: 11px;" />

        <HBox>
            <Button fx:id="saveButton" text="Save Changes" onAction="#handleSave"
                    styleClass="btn-primary" prefWidth="180" prefHeight="36" />
        </HBox>

    </VBox>
</VBox>
