<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" alignment="TOP_CENTER" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.CheckoutController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Button text="← Back to Menu" onAction="#handleBack" styleClass="flat" />
        <Label text="Checkout" style="-fx-font-size: 28px; -fx-font-weight: bold;" />
    </HBox>

    <HBox spacing="30.0" alignment="TOP_CENTER">
        <!-- Order Summary -->
        <VBox prefWidth="500.0" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20;">
            <Label text="Order Summary" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <ListView fx:id="summaryListView" prefHeight="300" />
            
            <Separator />
            
            <GridPane hgap="10" vgap="10">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" />
                    <ColumnConstraints halignment="RIGHT" />
                </columnConstraints>
                
                <Label text="Subtotal:" GridPane.rowIndex="0" />
                <Label fx:id="subtotalLabel" text="$0.00" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                
                <Label text="Discount Applied:" GridPane.rowIndex="1" style="-fx-text-fill: #cf222e;" />
                <Label fx:id="discountLabel" text="-$0.00" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-text-fill: #cf222e;" />
                
                <Label text="Total Amount:" GridPane.rowIndex="2" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
                <Label fx:id="totalLabel" text="$0.00" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0969da;" />
            </GridPane>
        </VBox>

        <!-- Payment & Coupon -->
        <VBox prefWidth="400.0" spacing="20.0">
            <VBox spacing="10.0" style="-fx-background-color: white; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20;">
                <Label text="Promo Code" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                <HBox spacing="10.0">
                    <TextField fx:id="couponField" promptText="Enter code" HBox.hgrow="ALWAYS" />
                    <Button text="Apply" onAction="#handleApplyCoupon" styleClass="btn-sm" />
                </HBox>
                <Label fx:id="couponMessageLabel" style="-fx-font-size: 12px;" />
            </VBox>

            <VBox spacing="10.0" style="-fx-background-color: white; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20;">
                <Label text="Payment Method" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                <RadioButton text="Cash on Delivery" selected="true" disable="true" />
                <Label text="Online payment is outside project scope." style="-fx-font-size: 11px; -fx-text-fill: #57606a; -fx-font-style: italic;" />
            </VBox>

            <Button text="Place Order" onAction="#handlePlaceOrder" maxWidth="Infinity" styleClass="btn-primary, btn-lg" prefHeight="60" />
            <Label fx:id="placeOrderMessageLabel" wrapText="true" alignment="CENTER" maxWidth="Infinity" />
        </VBox>
    </HBox>
</VBox>
