<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<VBox prefWidth="320.0" spacing="0" style="-fx-background-color: white; -fx-border-color: #d0d7de; -fx-border-radius: 10; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 6, 0, 0, 2);"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.RestaurantCardController">

    <!-- Cover image -->
    <StackPane prefHeight="160" prefWidth="320"
               style="-fx-background-radius: 10 10 0 0; -fx-background-color: #f6f8fa;">
        <ImageView fx:id="coverImage" fitWidth="320" fitHeight="160" preserveRatio="false"
                   style="-fx-background-radius: 10 10 0 0;" />
        <Label fx:id="newBadge" text="New" visible="false"
               style="-fx-background-color: #dafbe1; -fx-text-fill: #1a7f37; -fx-font-weight: bold;
                      -fx-padding: 3 10; -fx-background-radius: 12; -fx-font-size: 11px;"
               StackPane.alignment="TOP_RIGHT">
            <StackPane.margin><Insets top="10" right="10" /></StackPane.margin>
        </Label>
    </StackPane>

    <!-- Info -->
    <VBox spacing="6" style="-fx-padding: 14 15 14 15;">
        <Label fx:id="nameLabel" text="Restaurant Name"
               style="-fx-font-size: 17px; -fx-font-weight: bold;" />
        <HBox spacing="6" alignment="CENTER_LEFT">
            <Label fx:id="cuisineLabel" text="Cuisine Type"
                   style="-fx-text-fill: #57606a; -fx-font-size: 12px;" />
            <Label text="·" style="-fx-text-fill: #afb8c1;" />
            <Label fx:id="cityLabel" text="City"
                   style="-fx-text-fill: #57606a; -fx-font-size: 12px;" />
        </HBox>
        <Separator style="-fx-padding: 2 0;" />
        <HBox alignment="CENTER_LEFT" spacing="5.0">
            <Label fx:id="ratingLabel" text="★ 0.0"
                   style="-fx-font-weight: bold; -fx-text-fill: #9a6700;" />
            <Label fx:id="ratingCountLabel" text="(0 ratings)"
                   style="-fx-font-size: 12px; -fx-text-fill: #57606a;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="View Menu" onAction="#handleViewMenu" styleClass="btn-sm, btn-primary" />
        </HBox>
    </VBox>
</VBox>
