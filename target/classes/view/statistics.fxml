<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.StatisticsController">
    <VBox spacing="20.0">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="Monthly Performance" style="-fx-font-size: 28px; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <ComboBox fx:id="restaurantSelector" prefWidth="220" promptText="Select restaurant" />
            <Label text="Last 30 Days" style="-fx-text-fill: #57606a;" />
        </HBox>

        <!-- Key Metrics Cards -->
        <FlowPane hgap="20" vgap="20">
            <VBox prefWidth="240" spacing="5" style="-fx-background-color: white; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15;">
                <Label text="TOTAL REVENUE" style="-fx-font-size: 12px; -fx-text-fill: #57606a; -fx-font-weight: bold;" />
                <Label fx:id="totalRevenueLabel" text="0.00" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
            </VBox>
            <VBox prefWidth="240" spacing="5" style="-fx-background-color: white; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15;">
                <Label text="TOTAL ORDERS" style="-fx-font-size: 12px; -fx-text-fill: #57606a; -fx-font-weight: bold;" />
                <Label fx:id="totalOrdersLabel" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
            </VBox>
            <VBox prefWidth="240" spacing="5" style="-fx-background-color: white; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15;">
                <Label text="AVG ORDER VALUE" style="-fx-font-size: 12px; -fx-text-fill: #57606a; -fx-font-weight: bold;" />
                <Label fx:id="avgOrderLabel" text="0.00" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
            </VBox>
            <VBox prefWidth="240" spacing="5" style="-fx-background-color: white; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15;">
                <Label text="DISCOUNTS GIVEN" style="-fx-font-size: 12px; -fx-text-fill: #57606a; -fx-font-weight: bold;" />
                <Label fx:id="totalDiscountLabel" text="0.00" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #cf222e;" />
            </VBox>
        </FlowPane>

        <HBox spacing="20.0">
            <!-- Item-wise Sales Table -->
            <VBox HBox.hgrow="ALWAYS" spacing="10" style="-fx-background-color: white; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15;">
                <Label text="Item-wise Sales" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                <TableView fx:id="itemSalesTable" prefHeight="300">
                    <columns>
                        <TableColumn fx:id="itemNameCol" text="Item Name" prefWidth="200" />
                        <TableColumn fx:id="unitsSoldCol" text="Units Sold" prefWidth="100" />
                        <TableColumn fx:id="revenueCol" text="Revenue" prefWidth="120" />
                    </columns>
                </TableView>
            </VBox>

            <!-- Hall of Fame -->
            <VBox prefWidth="350" spacing="15" style="-fx-background-color: white; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15;">
                <Label text="Insights" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                
                <VBox spacing="2">
                    <Label text="Top Customer" style="-fx-font-size: 12px; -fx-text-fill: #57606a;" />
                    <Label fx:id="topCustomerLabel" text="N/A" style="-fx-font-weight: bold;" />
                </VBox>
                
                <VBox spacing="4">
                    <Label text="Highest Value Order" style="-fx-font-size: 12px; -fx-text-fill: #57606a;" />
                    <Label fx:id="highestOrderLabel" text="N/A" style="-fx-font-weight: bold;" />
                    <VBox fx:id="topOrderItemsBox" spacing="2" />
                </VBox>

                <VBox spacing="2">
                    <Label text="Most Popular Item" style="-fx-font-size: 12px; -fx-text-fill: #57606a;" />
                    <Label fx:id="popularItemLabel" text="N/A" style="-fx-font-weight: bold;" />
                </VBox>

                <VBox spacing="2">
                    <Label text="Highest Revenue Category" style="-fx-font-size: 12px; -fx-text-fill: #57606a;" />
                    <Label fx:id="topCategoryLabel" text="N/A" style="-fx-font-weight: bold;" />
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
