<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ProfileController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <Label text="My Profile" style="-fx-font-size: 28px; -fx-font-weight: bold;" />

    <HBox spacing="30.0">
        <!-- Main Details -->
        <VBox prefWidth="350.0" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20;">
            <Label text="Account Details" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            
            <GridPane hgap="15" vgap="15">
                <columnConstraints>
                    <ColumnConstraints prefWidth="100" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>

                <Label text="Username:" GridPane.rowIndex="0" style="-fx-font-weight: bold;" />
                <Label fx:id="usernameLabel" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Email:" GridPane.rowIndex="1" style="-fx-font-weight: bold;" />
                <Label fx:id="emailLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Default City:" GridPane.rowIndex="2" style="-fx-font-weight: bold;" />
                <Label fx:id="cityLabel" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <Label text="Account Type:" GridPane.rowIndex="3" style="-fx-font-weight: bold;" />
                <Label fx:id="typeLabel" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            </GridPane>
        </VBox>

        <!-- Multi-valued Attributes -->
        <VBox prefWidth="350.0" spacing="20.0">
            <VBox spacing="10.0" style="-fx-background-color: white; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20;">
                <Label text="Saved Addresses" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                <ListView fx:id="addressListView" prefHeight="100" />
            </VBox>

            <VBox spacing="10.0" style="-fx-background-color: white; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20;">
                <Label text="Saved Phone Numbers" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                <ListView fx:id="phoneListView" prefHeight="100" />
            </VBox>
        </VBox>
    </HBox>
</VBox>
