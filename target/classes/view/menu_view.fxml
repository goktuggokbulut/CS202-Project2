<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MenuViewController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <!-- Menu Items Section -->
    <VBox spacing="20.0" HBox.hgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Button text="← Back" onAction="#handleBack" styleClass="flat" />
            <VBox>
                <Label fx:id="restaurantNameLabel" text="Restaurant Name" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
                <Label fx:id="cuisineLabel" text="Cuisine Type" style="-fx-text-fill: #57606a;" />
            </VBox>
        </HBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
            <VBox fx:id="menuContainer" spacing="30.0">
                <!-- Categories and items will be injected here -->
            </VBox>
        </ScrollPane>
    </VBox>

    <!-- Cart Sidebar -->
    <VBox prefWidth="300.0" spacing="15.0" style="-fx-background-color: white; -fx-border-color: #d0d7de; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 15;">
        <Label text="Your Cart" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-width: 0;">
            <VBox fx:id="cartItemsBox" spacing="6" />
        </ScrollPane>

        <Separator />

        <HBox alignment="CENTER_LEFT">
            <Label text="Total:" style="-fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="totalLabel" text="0.00" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0969da;" />
        </HBox>

        <Button text="Checkout" onAction="#handleCheckout" maxWidth="Infinity" styleClass="btn-primary, btn-lg" />
    </VBox>
</HBox>
